# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build output ────────────────────────────────────────────────────────────
dist/
build/
out/
web/dist/
*.tsbuildinfo

# ── Caches ──────────────────────────────────────────────────────────────────
.cache/
.temp/
.turbo/
.vite/
.eslintcache
.stylelintcache

# ── Package-manager / runtime debug logs ────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-debug.log*

# ── Tests / coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Env / secrets (NEVER commit) ────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# ── Runtime / scratch ───────────────────────────────────────────────────────
tmp/
*.pid
*.seed
*.local

# ── Windows shortcuts (regenerated by misc/Create-Shortcut.ps1) ─────────────
*.lnk

# ── Editors / IDEs ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ── OS cruft ────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Project-local tooling (audit profile + run archives, not tracked) ───────
.arkitect/
.claude/
.saydeploy/
.agents/
