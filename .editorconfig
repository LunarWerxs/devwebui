# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Windows-native scripts keep CRLF (matches .gitattributes).
[*.{bat,cmd,ps1,vbs}]
end_of_line = crlf

# Don't trim trailing whitespace in Markdown (two spaces = hard line break).
[*.md]
trim_trailing_whitespace = false
