#!/bin/sh
# DevWebUI pre-commit gate: refuse a kit-synced file edited away from the kit.
# Enable once with:  git config core.hooksPath .githooks
# Bypass a single commit with:  git commit --no-verify
if command -v node >/dev/null 2>&1; then
  echo "› kit-sync guard…"
  node .githooks/check-kit-sync-staged.mjs devwebui || exit 1
fi
